# === Application ===
APP_NAME=agentic-rca-finder
APP_ENV=development
LOG_LEVEL=INFO

# === Server ===
HOST=0.0.0.0
PORT=8000

# === Agent ===
AGENT_MAX_ITERATIONS=8
AGENT_TIMEOUT_SECONDS=60

# === LLM ===
# One of: mock | openai
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500

# === Database (PostgreSQL, optional) ===
# Leave DATABASE_URL empty to keep the DB tool in "not connected" mode.
# When set, the query_database tool executes the allowlisted queries
# defined in app/tools/database_tool.py against this DSN.
# DATABASE_URL=postgresql://rca_ro:secret@localhost:5432/rca_ops
DATABASE_URL=
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5
DATABASE_QUERY_TIMEOUT_SECONDS=5.0
DATABASE_STATEMENT_TIMEOUT_MS=5000

# === Aerospike (NoSQL, optional) ===
# Leave AEROSPIKE_HOSTS empty to keep the Aerospike tool in "not
# connected" mode. Set both HOSTS + NAMESPACE to enable it. The tool
# runs only the allowlisted operations defined in
# app/tools/aerospike_tool.py.
# AEROSPIKE_HOSTS=cache-1.internal:3000,cache-2.internal:3000
# AEROSPIKE_NAMESPACE=insurance
AEROSPIKE_HOSTS=
AEROSPIKE_NAMESPACE=
AEROSPIKE_USERNAME=
AEROSPIKE_PASSWORD=
AEROSPIKE_TOTAL_TIMEOUT_MS=1000
AEROSPIKE_QUERY_TIMEOUT_SECONDS=2.0
