# === Application ===
APP_NAME=agentic-rca-finder
APP_ENV=development
LOG_LEVEL=INFO

# === Server ===
HOST=0.0.0.0
PORT=8000

# === Agent ===
AGENT_MAX_ITERATIONS=8
AGENT_TIMEOUT_SECONDS=60

# === LLM ===
# One of: mock | openai
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500
